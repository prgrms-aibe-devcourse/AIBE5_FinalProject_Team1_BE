# Copy this file to .env before running docker compose.

APP_IMAGE=codedock-backend:local
APP_PORT=8080
APP_REDIS_ENABLED=true
REDIS_HOST_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=2s
REDIS_CONNECT_TIMEOUT=2s
KAFKA_HOST_PORT=9092
SPRING_PROFILES_ACTIVE=docker

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=codedock-backend
KAFKA_CONSUMER_GROUP_ID=codedock
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
KAFKA_CONSUMER_ENABLE_AUTO_COMMIT=false
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3
KAFKA_PRODUCER_ENABLE_IDEMPOTENCE=true
KAFKA_PRODUCER_MAX_IN_FLIGHT_REQUESTS_PER_CONNECTION=5
KAFKA_LISTENER_ACK_MODE=record
KAFKA_LISTENER_MISSING_TOPICS_FATAL=false

# If Oracle runs on the host machine with Docker Desktop, use host.docker.internal.
# Example: jdbc:oracle:thin:@host.docker.internal:1521:orcl
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# Use a long random secret in real environments.
JWT_SECRET=

GITHUB_CLIENT_ID=local
GITHUB_CLIENT_SECRET=local

OAUTH2_REDIRECT_URI=http://localhost:5173/oauth/callback
OAUTH2_POPUP_REDIRECT_URI=http://localhost:5173/oauth/popup-callback
APP_BASE_URL=http://localhost:8080

APP_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
APP_WEBSOCKET_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
APP_LOCAL_NETWORK_ORIGIN_ENABLED=false

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# File upload (S3 presigned URL) — 채팅 이미지/파일 업로드
# 켜려면 UPLOAD_ENABLED=true + 버킷/공개URL + AWS 자격증명 필요
UPLOAD_ENABLED=false
UPLOAD_S3_BUCKET=
# 업로드 파일을 표시할 공개 베이스 URL (예: CloudFront 도메인). 끝에 / 없이
UPLOAD_PUBLIC_BASE_URL=
UPLOAD_REGION=ap-northeast-2
# S3 PutObject 권한이 있는 자격증명 (presigned URL 발급용)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
