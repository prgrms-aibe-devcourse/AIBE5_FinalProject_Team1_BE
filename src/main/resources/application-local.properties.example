# Database
DB_URL=jdbc:oracle:thin:@host:port:sid
DB_USERNAME=your_username
DB_PASSWORD=your_password

# JPA
spring.jpa.show-sql=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=2s
REDIS_CONNECT_TIMEOUT=2s

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=codedock-backend-local
KAFKA_CONSUMER_GROUP_ID=codedock
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
KAFKA_CONSUMER_ENABLE_AUTO_COMMIT=false
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3
KAFKA_PRODUCER_ENABLE_IDEMPOTENCE=true
KAFKA_PRODUCER_MAX_IN_FLIGHT_REQUESTS_PER_CONNECTION=5
KAFKA_LISTENER_ACK_MODE=record
KAFKA_LISTENER_MISSING_TOPICS_FATAL=false

# OAuth2
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long-for-hs256

# Groq
GROQ_API_KEY=your_groq_api_key

# Logging
logging.level.com.team1.codedock=DEBUG
logging.level.org.hibernate.SQL=DEBUG
